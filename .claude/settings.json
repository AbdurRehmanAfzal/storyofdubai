{
  "version": "1.0",
  "project": "storyofdubai",
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pytest:*)",
      "Bash(alembic:*)",
      "Bash(celery:*)",
      "Bash(uvicorn:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(echo:*)",
      "Bash(curl:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Read(*)",
      "Write(*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(DROP TABLE:*)",
      "Bash(DELETE FROM:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)"
    ]
  },
  "context": {
    "always_read": [
      "CLAUDE.md",
      "PROGRESS.md"
    ],
    "on_start": "Read CLAUDE.md and PROGRESS.md before any task. If PROGRESS.md has an IN PROGRESS task, ask the user if they want to continue it."
  },
  "agents": {
    "code_reviewer": ".claude/agents/code-reviewer.md",
    "security_auditor": ".claude/agents/security-auditor.md"
  },
  "style": {
    "language": "en",
    "verbosity": "normal",
    "always_update_progress": true
  }
}
