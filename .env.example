# .env.example — Copy this to .env and fill in values
# NEVER commit .env to Git — it contains secrets

# ═══════════════════════════════════════════════════════════════════════════
# DATABASE & CACHE
# ═══════════════════════════════════════════════════════════════════════════

# PostgreSQL (Async - for FastAPI)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/storyofdubai_dev

# PostgreSQL (Sync - for Alembic migrations)
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/storyofdubai_dev

# Alternative: Supabase (free tier)
# DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@[PROJECT].supabase.co:5432/postgres
# DATABASE_URL_SYNC=postgresql://postgres:[PASSWORD]@[PROJECT].supabase.co:5432/postgres

# Redis (Caching & Celery Broker)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ═══════════════════════════════════════════════════════════════════════════
# SECURITY & JWT
# ═══════════════════════════════════════════════════════════════════════════

# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-min-32-chars-change-this-in-production

# CORS allowed origins (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,storyofdubai.com,www.storyofdubai.com
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","https://storyofdubai.com"]

# JWT Token expiry (seconds)
JWT_EXPIRATION=604800  # 7 days

# ═══════════════════════════════════════════════════════════════════════════
# OPENAI API (GPT-4o-mini for AI Enrichment)
# ═══════════════════════════════════════════════════════════════════════════

# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Model configuration
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=400
OPENAI_TEMPERATURE=0.7

# ═══════════════════════════════════════════════════════════════════════════
# GOOGLE PLACES API (Restaurant, Hotel, Attraction Data)
# ═══════════════════════════════════════════════════════════════════════════

# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=AIzaSy...

# API configuration
GOOGLE_PLACES_BASE_URL=https://maps.googleapis.com/maps/api/place
GOOGLE_PLACES_RADIUS_METERS=30000  # 30km for Dubai

# ═══════════════════════════════════════════════════════════════════════════
# SCRAPING CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Rate limiting (minimum delay between requests to respect robots.txt)
SCRAPER_DELAY_SECONDS=2
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_MAX_RETRIES=3

# Proxy (optional - for rotating IPs)
SCRAPER_PROXY_URL=  # e.g., http://proxy.example.com:8080
SCRAPER_PROXY_USERNAME=
SCRAPER_PROXY_PASSWORD=

# User agent rotation
SCRAPER_USER_AGENT=StoryOfDubai/1.0 (+https://storyofdubai.com/robots.txt)

# ═══════════════════════════════════════════════════════════════════════════
# AI ENRICHMENT (Content Generation)
# ═══════════════════════════════════════════════════════════════════════════

# Enable/disable AI enrichment pipeline
AI_ENRICHMENT_ENABLED=true

# Similarity threshold (0-1) to detect duplicate content
AI_SIMILARITY_THRESHOLD=0.85

# Minimum composite score for enrichment (0-1)
AI_ENRICHMENT_MIN_SCORE=0.60

# ═══════════════════════════════════════════════════════════════════════════
# AFFILIATE NETWORKS
# ═══════════════════════════════════════════════════════════════════════════

# Viator (Tour & Experience Booking - 8% commission)
VIATOR_AFFILIATE_ID=

# Booking.com (Hotel Reservations - 25-30% commission)
BOOKING_AFFILIATE_ID=

# Bayut/PropertyFinder (Real Estate - $50-200 per lead)
BAYUT_AFFILIATE_ID=
PROPERTY_FINDER_AFFILIATE_ID=

# TheFork/Zomato (Restaurant Reservations)
THE_FORK_AFFILIATE_ID=

# ═══════════════════════════════════════════════════════════════════════════
# FRONTEND (NEXT.JS)
# ═══════════════════════════════════════════════════════════════════════════

# API URL (public, accessed from browser)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Site URL (for canonical tags, sitemaps, etc.)
NEXT_PUBLIC_SITE_URL=https://storyofdubai.com

# Google Analytics
NEXT_PUBLIC_GA_ID=

# ═══════════════════════════════════════════════════════════════════════════
# APPLICATION ENVIRONMENT
# ═══════════════════════════════════════════════════════════════════════════

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug mode (disable in production)
DEBUG=true

# Logging
LOG_LEVEL=INFO

# API configuration
API_V1_STR=/api/v1
PROJECT_NAME=Story of Dubai

# ═══════════════════════════════════════════════════════════════════════════
# MONITORING & ERROR TRACKING
# ═══════════════════════════════════════════════════════════════════════════

# Sentry (Error tracking)
SENTRY_DSN=

# ═══════════════════════════════════════════════════════════════════════════
# DEPLOYMENT (CI/CD & CDN)
# ═══════════════════════════════════════════════════════════════════════════

# Vercel (Frontend deployment)
VERCEL_TOKEN=

# Cloudflare (DNS, CDN, WAF)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ═══════════════════════════════════════════════════════════════════════════
# NOTES
# ═══════════════════════════════════════════════════════════════════════════

# 1. Copy this file: cp .env.example .env
# 2. Fill in all required values (marked with "...")
# 3. NEVER commit .env to Git
# 4. Never share .env file or API keys
# 5. For production, use environment variables on VPS
# 6. Rotate API keys every 90 days
# 7. Use different keys for dev/staging/production
