# .env.example - Copy this to .env and fill in values
# Never commit actual secrets - this file documents what's required

# === DATABASE ===
DATABASE_URL=postgresql://user:password@localhost:5432/storyofdubai_dev
# For Supabase: postgresql://postgres:[PASSWORD]@[PROJECT].supabase.co:5432/postgres

# === REDIS ===
REDIS_URL=redis://localhost:6379/0
# For production: redis://:[PASSWORD]@[HOST]:6379

# === API KEYS ===
OPENAI_API_KEY=sk-...
GOOGLE_PLACES_API_KEY=AIzaSy...
SECRET_KEY=your-super-secret-jwt-key-min-32-chars

# === CELERY ===
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# === APPLICATION ===
DEBUG=True
ENVIRONMENT=development
API_V1_STR=/api/v1
PROJECT_NAME=Story of Dubai

# === CORS ===
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# === NEXT.JS (FRONTEND) ===
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# === SCRAPING RATE LIMITS ===
SCRAPER_DELAY_SECONDS=2
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_MAX_RETRIES=3

# === AI ENRICHMENT ===
AI_MODEL=gpt-4o-mini
AI_ENRICHMENT_ENABLED=True
AI_SIMILARITY_THRESHOLD=0.85

# === MONITORING ===
SENTRY_DSN=
LOG_LEVEL=INFO

# === DEPLOYMENT ===
VERCEL_TOKEN=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
